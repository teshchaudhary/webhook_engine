DATABASE_URL=postgresql://webhook_user:webhook_password@localhost:5432/webhook_engine
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
PORT=3000
PROCESS_ROLE=all
ADMIN_API_KEY=replace-with-a-long-random-admin-key
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BASE_DELAY=1000
WEBHOOK_MAX_DELAY=300000
WEBHOOK_BACKOFF_MULTIPLIER=2
WEBHOOK_TIMEOUT=10000
WEBHOOK_SIGNATURE_ALGORITHM=sha256
WEBHOOK_MAX_TIMESTAMP_AGE=300
OUTBOX_POLL_INTERVAL=1000
STALE_DELIVERY_AGE=900000
WORKER_CONCURRENCY=10
MAX_REQUEST_BODY_SIZE=256kb
CAPTURE_WEBHOOK_RESPONSE_BODIES=false
EVENT_RETENTION_DAYS=0
